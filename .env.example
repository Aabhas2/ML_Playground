# API
API_PORT=8000
ENV=development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Postgres
POSTGRES_DB=ml_playground
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/ml_playground

# Redis
REDIS_URL=redis://redis:6379/0
RQ_QUEUE=default